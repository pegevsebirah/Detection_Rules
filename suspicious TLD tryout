tags:
    - TLD
    - domains
logsource:
    category: webserver
detection:
    selection_tld:
      cs-host|endswith:
        - ".icu"
        - ".ml"
        - ".py"
    selection_suspicicious:
      cs-uri | contains
        - "login"
        - "update"
        - "secure"
        - "verify"
        - "admin"
        - "definitely_not_phishing"
    condition: selection

falsepositives:
    - "enter here"
level: medium
